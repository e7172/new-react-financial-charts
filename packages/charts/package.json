{
    "name": "react-financial-charts-next",
    "version": "3.0.0",
    "description": "React charts specific to finance, updated for modern React.",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "author": "e7172",
    "keywords": [
        "charts",
        "charting",
        "stockcharts",
        "finance",
        "financial",
        "finance-chart",
        "react",
        "d3"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/e7172/new-react-financial-charts.git"
    },
    "bugs": {
        "url": "https://github.com/e7172/new-react-financial-charts/issues"
    },
    "homepage": "https://github.com/e7172/new-react-financial-charts#readme",
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsup --config tsup.config.ts",
        "clean": "rimraf dist",
        "typecheck": "tsc -p ../../tsconfig.build.json --noEmit"
    },
    "dependencies": {
        "d3-array": "^3.2.4",
        "d3-force": "^3.0.0",
        "d3-format": "^3.1.2",
        "d3-interpolate": "^3.0.1",
        "d3-scale": "^4.0.2",
        "d3-selection": "^3.0.0",
        "d3-shape": "^3.2.0",
        "d3-time": "^3.1.0",
        "d3-time-format": "^4.1.0",
        "lodash.flattendeep": "^4.4.0",
        "react-virtualized-auto-sizer": "^2.0.3"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0"
    }
}
